generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  name              String
  email             String             @unique
  password          String
  role              String             @default("employee")
  isVerified        Boolean            @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  refreshTokens     RefreshToken[]
  employeeProfile   EmployeeProfile?
  leaveRequests     LeaveRequest[]
  leaveApprovals    LeaveApproval[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  allocatedAssets   AssetAllocation[]  @relation("AllocatedTo")
  allocatedByAssets AssetAllocation[]  @relation("AllocatedBy")
  assetHistory      AssetHistory[]
  attendances       Attendance[]
  payrollRecords    PayrollRecord[]
  passwordResets    PasswordReset[]

  @@index([role])
  @@index([isVerified])
  @@index([createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Department {
  id             Int               @id @default(autoincrement())
  departmentName String            @unique
  createdAt      DateTime          @default(now())

  employeeProfiles EmployeeProfile[]
}

model EmployeeProfile {
  id           Int        @id @default(autoincrement())
  userId       Int        @unique
  departmentId Int?
  designation  String?
  phone        String?
  address      String?
  skills       String[]
  profileImage String?
  salary       Float?
  joiningDate  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([designation])
  @@index([salary])
  @@index([joiningDate])
}

model LeaveType {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  maxDays       Int
  createdAt     DateTime       @default(now())

  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id          Int             @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String
  status      String          @default("pending")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType   LeaveType       @relation(fields: [leaveTypeId], references: [id])
  approvals   LeaveApproval[]

  @@index([userId])
  @@index([status])
  @@index([leaveTypeId])
  @@index([startDate, endDate])
}

model LeaveApproval {
  id             Int          @id @default(autoincrement())
  leaveRequestId Int
  approverId     Int
  approverRole   String
  status         String
  comments       String?
  createdAt      DateTime     @default(now())

  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver       User         @relation(fields: [approverId], references: [id])

  @@index([leaveRequestId])
  @@index([approverId])
  @@index([status])
}

model LeaveBalance {
  id          Int      @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  year        Int
  totalDays   Int
  usedDays    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, leaveTypeId, year])
}

model Asset {
  id           Int               @id @default(autoincrement())
  assetCode    String            @unique
  assetName    String
  assetType    String
  purchaseDate DateTime?
  purchaseCost Float?
  status       String            @default("available")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  allocations  AssetAllocation[]
  history      AssetHistory[]

  @@index([status])
  @@index([assetType])
  @@index([assetName])
}

model AssetAllocation {
  id            Int       @id @default(autoincrement())
  assetId       Int
  employeeId    Int
  allocatedById Int
  allocatedDate DateTime  @default(now())
  returnDate    DateTime?
  status        String    @default("allocated")

  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee      User      @relation("AllocatedTo", fields: [employeeId], references: [id])
  allocatedBy   User      @relation("AllocatedBy", fields: [allocatedById], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@index([status])
}

model AssetHistory {
  id          Int      @id @default(autoincrement())
  assetId     Int
  action      String
  remarks     String?
  createdById Int
  createdAt   DateTime @default(now())

  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([assetId])
  @@index([createdById])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tableName   String
  actionType  String
  recordId    Int
  oldData     Json?
  newData     Json?
  performedBy Int
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [performedBy], references: [id])

  @@index([performedBy])
  @@index([tableName])
  @@index([actionType])
  @@index([createdAt])
}
// ─── TASK 7: PAYROLL & ATTENDANCE ─────────────────────────────

model Attendance {
  id          Int       @id @default(autoincrement())
  userId      Int
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String    @default("absent") // present | late | absent | holiday
  workHours   Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([status])
}

model PayrollRecord {
  id               Int       @id @default(autoincrement())
  userId           Int
  month            Int
  year             Int
  grossSalary      Float
  workingDays      Int       @default(26)
  presentDays      Int       @default(0)
  absentDays       Int       @default(0)
  lateDays         Int       @default(0)
  absentDeduction  Float     @default(0)
  lateDeduction    Float     @default(0)
  pfDeduction      Float     @default(0)
  esicDeduction    Float     @default(0)
  totalDeductions  Float     @default(0)
  netSalary        Float
  status           String    @default("draft") // draft | generated | paid
  generatedAt      DateTime  @default(now())
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  salarySlip       SalarySlip?

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
  @@index([status])
}

model SalarySlip {
  id              Int           @id @default(autoincrement())
  payrollRecordId Int           @unique
  slipNumber      String        @unique
  generatedAt     DateTime      @default(now())

  payrollRecord   PayrollRecord @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)

  @@index([payrollRecordId])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
